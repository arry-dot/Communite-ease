rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY: Allow public access to bypass login errors for prototyping
    match /{document=**} {
      allow read, write: if true;
    }

    // --- Helpers kept for future hardening ---
    function isSignedIn() {
      return true; // Mock true for bypass
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based helper
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Entity Validations ---

    function isValidIssue(data) {
      return data.keys().hasAll(['title', 'reporterUid', 'status', 'createdAt', 'category', 'imageUrl', 'description', 'votes'])
        && data.title is string && data.title.size() <= 100
        && data.reporterUid == request.auth.uid
        && data.status in ['pending', 'verified', 'critical']
        && data.category is string
        && data.imageUrl is string
        && data.description is string && data.description.size() <= 1000
        && data.votes is number
        && data.createdAt == request.time;
    }

    function isValidSurvey(data) {
      return data.keys().hasAll(['need', 'location', 'severity', 'processedAt', 'processedByUid'])
        && data.need is string && data.need.size() <= 200
        && data.location is string
        && data.severity is number && data.severity >= 1 && data.severity <= 5
        && data.processedByUid == request.auth.uid
        && data.processedAt == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'level', 'avatar', 'repPoints', 'reportsCount', 'votesCount', 'badges'])
        && data.name is string && data.name.size() <= 50
        && data.level is number
        && data.repPoints is number
        && data.reportsCount is number
        && data.votesCount is number
        && data.badges is list && data.badges.size() <= 20;
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'level', 'repPoints', 'reportsCount', 'votesCount', 'badges']);
    }

    match /issues/{issueId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(issueId) && isValidIssue(incoming());
      allow update: if isSignedIn() && (
        // Action: Vote
        (incoming().diff(existing()).affectedKeys().hasOnly(['votes']) && incoming().votes == existing().votes + 1)
        // Action: NGO status update
        || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    match /surveys/{surveyId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(surveyId) && isValidSurvey(incoming());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
